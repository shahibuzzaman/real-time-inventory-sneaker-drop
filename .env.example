# Root convenience variables (copy relevant ones into app-specific .env files)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sneaker_drop
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sneaker_drop_test
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# API
PORT=3001
CORS_ORIGIN=http://localhost:5173
WORKER_URL=http://localhost:3002
WORKER_TOKEN=change-me
JWT_SECRET=local-dev-jwt-secret
JWT_REFRESH_SECRET=local-dev-refresh-jwt-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_SECONDS=2592000
REFRESH_TOKEN_COOKIE_NAME=refreshToken

# Socket Worker
SOCKET_CORS_ORIGIN=http://localhost:5173
EXPIRY_INTERVAL_MS=2000

# Client
VITE_API_BASE_URL=
VITE_SOCKET_URL=http://localhost:3002
