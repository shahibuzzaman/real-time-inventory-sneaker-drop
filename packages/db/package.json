    "umzug": "^3.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^8.57.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
